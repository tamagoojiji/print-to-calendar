# ===== print-to-calendar backend 環境変数サンプル =====
# VPS上で `cp env.sample .env` してから実値を記入（.env はコミットしない）

PORT=8787
DB_PATH=./data/ptc.db

# CORS許可オリジン（カンマ区切り）。本番はGitHub Pagesオリジン。
CORS_ORIGINS=http://localhost:5173,https://tamagoojiji.github.io

# --- Gemini（画像解析。サーバー側でのみ使用）---
GEMINI_API_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# --- Google OAuth（サーバー側フロー）---
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
# OAuthコールバック。バックエンドの公開URL + /api/google/oauth/callback
GOOGLE_REDIRECT_URI=https://api.example.com/api/google/oauth/callback

# --- 署名/暗号化シークレット（本番では必ずランダムな長い値に変更）---
# 生成例: openssl rand -hex 32
LICENSE_SECRET=
TOKEN_ENCRYPTION_SECRET=

# --- Discord 同期エラー通知 ---
DISCORD_ERROR_WEBHOOK_URL=

# --- フロント（PWA）公開URL。OAuthコールバック後のリダイレクト先 ---
APP_BASE_URL=https://tamagoojiji.github.io/print-to-calendar/

# --- 管理画面トークン ---
ADMIN_TOKEN=
